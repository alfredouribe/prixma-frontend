{
  "expo": {
    "name": "Prixma",
    "slug": "prixma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./brand/assets/logo/png/prixma_icon_color.png",
    "userInterfaceStyle": "dark",
    "scheme": "prixma",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.prixma.mobile"
    },
    "android": {
      "package": "app.prixma.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./brand/assets/logo/png/prixma_icon_white.png",
        "backgroundColor": "#9b5dff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Prixma necesita tu ubicación para mostrarte personas cercanas."
        }
      ],
      "expo-splash-screen",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
